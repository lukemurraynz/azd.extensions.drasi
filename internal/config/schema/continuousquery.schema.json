{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContinuousQuery",
  "type": "object",
  "required": ["APIVersion", "Kind", "ID", "Query"],
  "properties": {
    "APIVersion": { "type": "string" },
    "Kind": { "type": "string", "const": "ContinuousQuery" },
    "ID": { "type": "string" },
    "QueryLanguage": { "type": "string" },
    "Sources": { "type": "array" },
    "Query": { "type": "string" },
    "Reactions": { "type": "array", "items": { "type": "string" } },
    "AutoStart": { "type": "boolean" }
  }
}
