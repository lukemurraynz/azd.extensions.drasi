{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DrasiManifest",
  "type": "object",
  "required": ["APIVersion"],
  "properties": {
    "APIVersion": { "type": "string" },
    "Includes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["Kind", "Pattern"],
        "properties": {
          "Kind": { "type": "string" },
          "Pattern": { "type": "string" }
        }
      }
    },
    "Environments": { "type": "object" },
    "FeatureFlags": { "type": "object" },
    "SecretMappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vaultName", "secretName", "k8sSecret", "k8sKey"],
        "properties": {
          "vaultName": { "type": "string", "description": "Azure Key Vault name. Supports $(VARNAME) expansion." },
          "secretName": { "type": "string", "description": "Secret name within the Key Vault." },
          "k8sSecret": { "type": "string", "description": "Kubernetes Secret name to create/update." },
          "k8sKey": { "type": "string", "description": "Key within the Kubernetes Secret." },
          "namespace": { "type": "string", "description": "Kubernetes namespace. Defaults to drasi-system." }
        }
      }
    }
  }
}
