{
  "version": 1,
  "extensions": [
    {
      "displayName": "Drasi for Azure Developer CLI",
      "id": "azure.drasi",
      "description": "Manage Drasi reactive data pipeline workloads with azd.",
      "namespace": "drasi",
      "versions": [
        {
          "requiredAzdVersion": ">=1.10.0",
          "examples": [
            {
              "description": "Show component health and deployment state.",
              "usage": "azd drasi status",
              "name": "status"
            }
          ],
          "usage": "azd drasi <command> [options]",
          "capabilities": [
            "custom-commands",
            "lifecycle-events"
          ],
          "artifacts": {
            "windows/amd64": {
              "entryPoint": "azd-drasi.exe",
              "url": "./artifacts/azd-drasi.exe"
            }
          },
          "version": "1.0.0"
        }
      ]
    }
  ]
}
